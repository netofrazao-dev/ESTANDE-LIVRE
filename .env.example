# Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Configurações da locadora
VITE_MAX_BOOKS_PER_RENTAL=3
VITE_RENTAL_DAYS=14
VITE_DAILY_FINE=2.00

# Monitoramento de erros (opcional — deixe em branco para desativar)
# Crie um projeto em sentry.io e cole o DSN aqui
VITE_SENTRY_DSN=

# Captcha no cadastro (opcional — deixe em branco para desativar)
# Crie um site em https://dash.cloudflare.com/?to=/:account/turnstile
# e cole a Site Key aqui (a Secret Key vai no painel do Supabase, não aqui)
VITE_TURNSTILE_SITE_KEY=
